# ── AI API Keys ─────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# ── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# Updated automatically by docker-compose — change only for custom deployments
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/incident_agent
REDIS_URL=redis://redis:6379/0

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434

# ── Budget controls ───────────────────────────────────────────────────────────
BUDGET_DAILY_USD=10.0

# ── CORS (add your domain in production) ─────────────────────────────────────
# CORS_ORIGINS=["https://your-domain.com"]
